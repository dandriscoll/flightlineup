{
  "name": "flightlineup",
  "version": "2.0.0",
  "description": "Flight Lineup - Formation flight visualization tool",
  "scripts": {
    "build": "parcel build src/index.tsx --dist-dir dist",
    "serve": "parcel serve --no-cache index.html --host 0.0.0.0 --public-url / --log-level verbose",
    "watch": "parcel watch src/index.tsx --dist-dir . --host 0.0.0.0 --public-url / --hmr-host mataf.driscoll.house",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "html2canvas": "^1.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@parcel/transformer-less": "^2.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "less": "^4.2.0",
    "nodemon": "^3.0.2",
    "parcel": "^2.10.3",
    "process": "^0.11.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.2"
  }
}
